# Environment Configuration for AI QA Agent
# Copy this file to .env and fill in your values

# ==============================================================================
# LLM Configuration
# ==============================================================================
# Set your LLM API key here. If not set, the application will use mock responses.
# Supports: OpenAI, Anthropic, and other compatible LLM providers
# LLM_API_KEY=sk-your-api-key-here
# LLM_PROVIDER=openai

# ==============================================================================
# Server Configuration
# ==============================================================================
# Host and port for FastAPI server
HOST=0.0.0.0
PORT=8000

# Enable debug mode (set to False in production)
DEBUG=True

# ==============================================================================
# Document Processing
# ==============================================================================
# Maximum file upload size (in bytes)
# Default: 52428800 (50MB)
MAX_UPLOAD_SIZE=52428800

# Upload timeout (in seconds)
UPLOAD_TIMEOUT=300

# ==============================================================================
# Application Settings
# ==============================================================================
# Application name and version
APP_NAME=AI QA Agent
APP_VERSION=1.0.0

# Enable CORS for all origins (set to specific origins in production)
CORS_ORIGINS=*

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
